# ─────────────────────────────────────────────────────────────
# Site Factory — environment variables (template)
# Copy values into .env.local. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# Public site config (Site #1)
NEXT_PUBLIC_SITE_URL=https://whichaitool.com
NEXT_PUBLIC_SITE_NAME=WhichAITool

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API (for content generation pipelines)
ANTHROPIC_API_KEY=

# Google AI (Gemini) — fallback / batch
GOOGLE_API_KEY=

# Cloudflare (analytics, image resize)
CLOUDFLARE_ANALYTICS_TOKEN=

# SNS automation (added in Phase 2)
PINTEREST_ACCESS_TOKEN=
YOUTUBE_API_KEY=

# YouTube Data API v3 — OAuth2 (for video-factory auto-upload)
# Setup: Google Cloud Console → enable YouTube Data API v3 → create OAuth Desktop client
# Then run: cd apps/video-factory && npm run youtube-auth
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
TIKTOK_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN=
X_API_BEARER_TOKEN=

# ElevenLabs (video voiceover)
ELEVENLABS_API_KEY=

# Affiliate networks (added in Phase 3)
IMPACT_API_KEY=
PARTNERSTACK_API_KEY=

# Google AdSense (Phase 1)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# Vercel Cron (Pinterest auto-posting)
# CRON_SECRET: random hex string used to authenticate Vercel cron requests.
#   Generate locally: openssl rand -hex 32
# BLOB_READ_WRITE_TOKEN: auto-injected by Vercel when a Blob store is connected
#   (Vercel dashboard → Storage → Connect Blob). Used as state for posted pins.
CRON_SECRET=
BLOB_READ_WRITE_TOKEN=
